.pdm-python

# macOS files
*.DS_Store
*.benchmarks

# working scratch files
.scratch*

# Rust build output
target/
**/target/

# Per-run benchmark output (baseline is committed; current-run is ephemeral).
migration/artifacts/rust_latency_current.json
# Stale live-legacy bench artifact (superseded by rust_latency_baseline.json +
# migration/artifacts/history/rust_vs_legacy_final_snapshot_*.json).
migration/artifacts/rust_benchmark_gate.json
